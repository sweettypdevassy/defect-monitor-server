ibm:
  auth_method: password  # Using username/password authentication
  username: "your-ibm-email@ibm.com"
  password: "your-password-here"
  build_break_url: "https://libh-proxy1.fyre.ibm.com/buildBreakReport"
  soe_triage_url: "https://wasrtc.hursley.ibm.com:9443/jazz/web/projects/WS-CD#action=com.ibm.team.workitem.runSavedQuery&id=_fJ834OXIEemRB5enIPF1MQ"
  session_timeout: 28800  # 8 hours

slack:
  webhook_url: "https://hooks.slack.com/triggers/YOUR/WEBHOOK/URL"
  channel: "#defect-notifications"
  username: "Defect Monitor Bot"
  icon_emoji: ":bug:"

# ML Training Configuration
ml_training:
  # Components to use for training the ML model
  # If empty or not specified, will use all_components
  training_components: []
  
  # Weekly retraining schedule
  retrain_day: "thursday"  # Day of week for retraining
  retrain_time: "10:00"    # Time in HH:MM format (IST)

# Team-based monitoring (NEW!)
# Each team has its own components, schedule, and Slack webhook
teams:
  - name: "Team 1"
    components:
      - name: "Batch"
        notify: true
      - name: "Messaging"
        notify: true
    check_time: "10:00"  # HH:MM format (IST)
    skip_weekends: true  # Skip Saturday and Sunday
    webhook_url: "https://hooks.slack.com/triggers/YOUR/TEAM1/WEBHOOK"
    slack_channel: "#team1-defects"
    weekly_dashboard_day: "friday"   # Send weekly dashboard every Friday
    weekly_dashboard_time: "17:00"   # At 5:00 PM IST

  - name: "Team 2"
    components:
      - name: "JPA"
        notify: true
      - name: "JCA"
        notify: true
      - name: "Bean Validation"
        notify: true
    check_time: "10:30"  # Different time for this team
    skip_weekends: true
    webhook_url: "https://hooks.slack.com/triggers/YOUR/TEAM2/WEBHOOK"
    slack_channel: "#team2-defects"
    weekly_dashboard_day: "friday"
    weekly_dashboard_time: "17:00"

# Legacy monitored components (used if teams not configured)
# monitored_components:
#   - name: "Spring Boot"
#     notify: true
#     slack_channel: "#springboot-defects"

all_components:
  - AdminCenter
  - App Client
  - Async Scheduling (Persistent Executor, CommonJ)
  - Batch
  - Bean Validation
  - Build
  - CDI
  - Classloading
  - Cloud/Virtualization
  - Core Security
  - Database (jdbc, oracle, db2, derby)
  - Docs
  - Dynacache
  - EE / MP Concurrency
  - EJB Container
  - IIOP/ORB
  - IBM i
  - Install
  - InstantOn
  - Intelligent Management
  - JAX-RS
  - Jakarta Data
  - Java EE Platform
  - JCA
  - JPA
  - JSON
  - Kernel/Bootstrap
  - MCP
  - Messaging
  - MicroProfile Core (config, fault tolerance, reactive)
  - MicroProfile GraphQL
  - MicroProfile Observability (metrics, open tracing, health)
  - MicroProfile Open API
  - MicroProfile REST Client
  - Mongo
  - OSGi Applications
  - Observability
  - Real-Time Comm (WebRTC, SIP)
  - Repository
  - Security SSO (jwt, oauth, oidc, social, mpjwt, saml)
  - Spring Boot
  - Systems Management
  - Transactions
  - Transport (cfw, http, ssl, websockets)
  - Usage Metering
  - WAS on Cloud
  - Web Comps (servlet, httpsession, jsp, jsf, etc)
  - Web Services
  - Web Services Security
  - WebSphere Automation
  - z/OS

schedule:
  # Legacy daily check (used if teams not configured)
  # daily_check_time: "10:00"  # HH:MM format (IST)
  # skip_weekends: true
  
  # Dashboard and background tasks
  all_components_fetch_time: "09:00"  # Background fetch for dashboard (runs before team checks)
  
  # For testing: specify components to fetch (if empty, fetches all_components)
  test_components: []
  
  timezone: "Asia/Kolkata"

dashboard:
  port: 5000
  host: "0.0.0.0"
  public_url: "http://your-server-ip:5001/dashboard"
  secret_key: "change-this-to-random-secret-key"
  retention_days: 90
  enable_component_explorer: true

database:
  type: "sqlite"
  path: "data/defects.db"

# Feature flags
features:
  all_components_tracking: true  # Enable background fetch for all components (for dashboard)

# Notification settings
notifications:
  only_notify_monitored: true  # Only send notifications for monitored components

logging:
  level: "INFO"

  