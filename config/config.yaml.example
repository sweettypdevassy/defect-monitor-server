ibm:
  auth_method: cookies  # or "password" or "browser_cookies"
  cookies:
    LtpaToken2: "YOUR_LTPA_TOKEN_HERE"
    mod_auth_openidc_session: "YOUR_SESSION_ID_HERE"
  username: "your.email@ibm.com"
  password: "your_password_here"
  build_break_url: "https://libh-proxy1.fyre.ibm.com/buildBreakReport"
  soe_triage_url: "https://wasrtc.hursley.ibm.com:9443/jazz/web/projects/WS-CD#action=com.ibm.team.workitem.runSavedQuery&id=_fJ834OXIEemRB5enIPF1MQ"
  session_timeout: 28800  # 8 hours

slack:
  webhook_url: "https://hooks.slack.com/triggers/YOUR/WEBHOOK/URL"
  channel: "#defect-notifications"
  username: "Defect Monitor Bot"
  icon_emoji: ":bug:"

# ML Training Configuration
ml_training:
  # Components to use for training the ML model
  # If empty or not specified, will use all_components
  training_components:
    - Spring Boot
    # - JCA
    # - Messaging
  
  # Weekly retraining schedule
  retrain_day: "saturday"  # Day of week for retraining
  retrain_time: "10:00"    # Time in HH:MM format (IST)

# Team-based monitoring (NEW!)
# Each team has its own components, schedule, and Slack webhook
teams:
  - name: "Spring Boot Team"
    components:
      - name: "Spring Boot"
        notify: true
        slack_channel: "#springboot-defects"
    check_time: "10:00"  # HH:MM format (IST)
    skip_weekends: true  # Skip Saturday and Sunday
    webhook_url: "https://hooks.slack.com/triggers/YOUR/SPRINGBOOT/WEBHOOK"
    slack_channel: "#springboot-defects"
  
  - name: "Messaging Team"
    components:
      - name: "Messaging"
        notify: true
        slack_channel: "#messaging-defects"
      - name: "JCA"
        notify: true
        slack_channel: "#messaging-defects"
    check_time: "11:00"  # Different time for this team
    skip_weekends: true
    webhook_url: "https://hooks.slack.com/triggers/YOUR/MESSAGING/WEBHOOK"
    slack_channel: "#messaging-defects"
  
  - name: "Database Team"
    components:
      - name: "Database (jdbc, oracle, db2, derby)"
        notify: true
        slack_channel: "#database-defects"
      - name: "JPA"
        notify: true
        slack_channel: "#database-defects"
    check_time: "14:00"  # Afternoon check
    skip_weekends: true
    webhook_url: "https://hooks.slack.com/triggers/YOUR/DATABASE/WEBHOOK"
    slack_channel: "#database-defects"

# Legacy monitored components (used if teams not configured)
monitored_components:
  - name: "Spring Boot"
    notify: true
    slack_channel: "#springboot-defects"
  # Add more monitored components here
  # - name: "JCA"
  #   notify: true
  #   slack_channel: "#jca-defects"

all_components:
  - AdminCenter
  - App Client
  - Async Scheduling (Persistent Executor, CommonJ)
  - Batch
  - Bean Validation
  - Build
  - CDI
  - Classloading
  - Cloud/Virtualization
  - Core Security
  - Database (jdbc, oracle, db2, derby)
  - Docs
  - Dynacache
  - EE / MP Concurrency
  - EJB Container
  - IIOP/ORB
  - IBM i
  - Install
  - InstantOn
  - Intelligent Management
  - JAX-RS
  - Jakarta Data
  - Java EE Platform
  - JCA
  - JPA
  - JSON
  - Kernel/Bootstrap
  - MCP
  - Messaging
  - MicroProfile Core (config, fault tolerance, reactive)
  - MicroProfile GraphQL
  - MicroProfile Observability (metrics, open tracing, health)
  - MicroProfile Open API
  - MicroProfile REST Client
  - Mongo
  - OSGi Applications
  - Observability
  - Real-Time Comm (WebRTC, SIP)
  - Repository
  - Security SSO (jwt, oauth, oidc, social, mpjwt, saml)
  - Spring Boot
  - Systems Management
  - Transactions
  - Transport (cfw, http, ssl, websockets)
  - Usage Metering
  - WAS on Cloud
  - Web Comps (servlet, httpsession, jsp, jsf, etc)
  - Web Services
  - Web Services Security
  - WebSphere Automation
  - z/OS

schedule:
  # Legacy daily check (used if teams not configured)
  daily_check_time: "10:00"  # HH:MM format (IST)
  skip_weekends: true  # NEW: Skip Saturday and Sunday
  
  # Dashboard and background tasks
  weekly_dashboard_day: "monday"
  weekly_dashboard_time: "11:00"
  all_components_fetch_time: "09:00"  # Background fetch for dashboard (optimized - no ML/duplicate detection)
  timezone: "Asia/Kolkata"

dashboard:
  port: 5000
  host: "0.0.0.0"
  public_url: "http://YOUR_VM_IP:5000/dashboard"
  secret_key: "change-this-to-random-secret-key"
  retention_days: 90
  enable_component_explorer: true

database:
  type: "sqlite"
  path: "data/defects.db"

# Feature flags
features:
  all_components_tracking: true  # Enable background fetch for all components (for dashboard)

# Notification settings
notifications:
  only_notify_monitored: true  # Only send notifications for monitored components

logging:
  level: "INFO"